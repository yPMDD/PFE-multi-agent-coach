# Groq API Key - REQUIRED - Get from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# PostgreSQL (configured in docker-compose)
POSTGRES_USER=pfe
POSTGRES_PASSWORD=pfe_secret
POSTGRES_DB=pfe_coach
DATABASE_URL=postgresql://pfe:pfe_secret@postgres:5432/pfe_coach

# ChromaDB
CHROMA_PERSIST_PATH=/app/chroma_db

# FastAPI
FASTAPI_PORT=8000

# Tavily Web Search - Get free key at https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Firebase - Replace with your own config from Firebase Console
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id